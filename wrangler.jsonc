{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sink",
  "main": ".output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public",
    "html_handling": "drop-trailing-slash"
  },
  "compatibility_date": "2025-05-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "keep_vars": true,
  "upload_source_maps": true,
  "observability": {
    "logs": {
      "enabled": true
    },
    "traces": {
      "enabled": true
    }
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  // Values marked with DEPLOY_* below are placeholders for local/dev.
  // CLI deploy (pnpm deploy:worker / deploy:config) rewrites them into gitignored wrangler.deploy.jsonc.
  // Prefer setting DEPLOY_* in .env or Workers Builds / Pages variables — do not hardcode production IDs here.
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "sink" // Override with DEPLOY_ANALYTICS_DATASET (default: sink). Keep in sync with NUXT_DATASET at runtime.
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "preview_id": "083dbc6ef95741a7bf9d087e5ef1b810", // Override with DEPLOY_KV_PREVIEW_NAMESPACE_ID (falls back to DEPLOY_KV_NAMESPACE_ID)
      "id": "083dbc6ef95741a7bf9d087e5ef1b810" // Override with DEPLOY_KV_NAMESPACE_ID
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sink", // Override with DEPLOY_D1_DATABASE_NAME (default: sink)
      "database_id": "1b68046f-60ab-4903-b7cb-eda508c3d638", // Override with DEPLOY_D1_DATABASE_ID (required for CLI deploy)
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      // preview_bucket_name: DEPLOY_R2_PREVIEW_BUCKET_NAME (falls back to DEPLOY_R2_BUCKET_NAME)
      // omit DEPLOY_R2_BUCKET_NAME to drop R2 from generated deploy config
      "preview_bucket_name": "pan",
      "bucket_name": "pan" // Override with DEPLOY_R2_BUCKET_NAME
    }
  ],
  "triggers": {
    "crons": ["0 0 * * *"] // Run backup task daily at 00:00 UTC
  }
}
